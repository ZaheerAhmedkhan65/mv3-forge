{
  "name": "@mv3-forge/monorepo",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "A monorepo for mv3-forge browser extension tooling",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "tsc --noEmit",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "latest",
    "husky": "^9.0.0",
    "eslint": "^8.0.0",
    "@eslint/js": "^8.0.0",
    "typescript-eslint": "^7.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "extension",
    "chrome",
    "browser",
    "mv3-forge",
    "manifest-v3",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.1.0"
}