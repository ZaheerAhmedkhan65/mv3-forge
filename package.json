{
  "name": "mv3-forge",
  "version": "0.1.2",
  "type": "module",
  "description": "A CLI tool for creating browser extensions",
  "bin": {
    "mv3-forge": "./packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist",
    "packages/core/dist",
    "packages/shared/dist",
    "templates"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "latest",
    "husky": "^9.0.0",
    "eslint": "^8.0.0",
    "@eslint/js": "^8.0.0",
    "typescript-eslint": "^7.0.0",
    "prettier": "^3.0.0"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "@clack/prompts": "^0.7.0",
    "picocolors": "^1.0.0"
  },
  "keywords": [
    "extension",
    "chrome",
    "browser",
    "mv3-forge",
    "manifest-v3",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@9.1.0"
}