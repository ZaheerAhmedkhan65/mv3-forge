{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@mv3-forge/shared": [
        "packages/shared/src/index.ts"
      ],
      "@mv3-forge/core": [
        "packages/core/src/index.ts"
      ],
      "mv3-forge": [
        "packages/cli/src/index.ts"
      ]
    }
  }
}
