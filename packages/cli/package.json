{
  "name": "mv3-forge",
  "version": "0.1.2",
  "description": "A CLI tool for creating Manifest V3 browser extensions",
  "bin": {
    "mv3-forge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "type": "module",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src --fix"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0"
  },
